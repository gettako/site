{
  "name": "tako",
  "version": "1.0.0",
  "description": "Tako framework documentation site",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "docs:api": "bash scripts/gen-api.sh",
    "deploy": "bun run docs:build && bunx wrangler pages deploy .vitepress/dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/iosevka": "^5.2.5",
    "@tabler/icons-vue": "^3.44.0"
  },
  "devDependencies": {
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/vite": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.53.0",
    "tailwindcss": "^4.3.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.4.27"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue,css}": [
      "oxfmt"
    ]
  }
}
